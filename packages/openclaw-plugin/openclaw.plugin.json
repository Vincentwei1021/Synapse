{
  "id": "synapse-openclaw-plugin",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "synapse_checkin",
      "synapse_list_research_projects",
      "synapse_get_research_project",
      "synapse_get_project_full_context",
      "synapse_get_activity",
      "synapse_get_research_questions",
      "synapse_get_research_question",
      "synapse_get_available_research_questions",
      "synapse_claim_research_question",
      "synapse_release_research_question",
      "synapse_update_research_question_status",
      "synapse_get_experiment",
      "synapse_get_assigned_experiments",
      "synapse_start_experiment",
      "synapse_submit_experiment_results",
      "synapse_report_experiment_progress",
      "synapse_update_experiment_status",
      "synapse_create_experiment",
      "synapse_propose_experiment",
      "synapse_review_experiment",
      "synapse_update_experiment_plan",
      "synapse_list_compute_nodes",
      "synapse_get_node_access_bundle",
      "synapse_sync_node_inventory",
      "synapse_reserve_gpus",
      "synapse_report_gpu_status",
      "synapse_get_repo_access",
      "synapse_get_documents",
      "synapse_get_document",
      "synapse_save_experiment_report",
      "synapse_upload_document_image",
      "synapse_add_comment",
      "synapse_get_comments",
      "synapse_get_notifications",
      "synapse_mark_notification_read",
      "synapse_search_mentionables",
      "synapse_get_project_groups",
      "synapse_get_project_group",
      "synapse_get_group_dashboard",
      "synapse_search_papers",
      "synapse_add_related_work",
      "synapse_get_related_works",
      "synapse_read_paper_brief",
      "synapse_read_paper_head",
      "synapse_read_paper_section",
      "synapse_read_paper_full",
      "synapse_complete_task",
      "synapse_save_project_synthesis",
      "synapse_get_deep_research_report",
      "synapse_save_deep_research_report",
      "synapse_list_sessions",
      "synapse_get_session",
      "synapse_create_session",
      "synapse_close_session",
      "synapse_reopen_session",
      "synapse_session_heartbeat"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "synapseUrl": {
        "type": "string",
        "description": "Synapse server URL"
      },
      "apiKey": {
        "type": "string",
        "description": "Synapse API Key (syn_ prefix)"
      },
      "projectUuids": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "Project UUIDs to monitor (empty = all)"
      },
      "autoStart": {
        "type": "boolean",
        "default": true,
        "description": "Automatically wake the agent when new experiments are assigned"
      }
    }
  }
}
