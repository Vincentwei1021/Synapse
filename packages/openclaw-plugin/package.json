{
  "name": "@vincentwei1021/synapse-openclaw-plugin",
  "version": "0.10.24",
  "description": "OpenClaw plugin for Synapse research orchestration — SSE notifications, MCP tools, experiment lifecycle, autonomous loop",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "rm -rf dist && pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "cd ../.. && pnpm exec vitest run packages/openclaw-plugin/src/event-router.test.ts packages/openclaw-plugin/src/mcp-client.test.ts packages/openclaw-plugin/src/runtime-agent.test.ts packages/openclaw-plugin/src/sse-listener.test.ts"
  },
  "peerDependencies": {
    "openclaw": ">=2026.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  },
  "openclaw": {
    "extensions": ["dist/index.js"]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vincentwei1021/Synapse",
    "directory": "packages/openclaw-plugin"
  },
  "homepage": "https://github.com/Vincentwei1021/Synapse",
  "keywords": ["openclaw", "synapse", "research", "mcp", "plugin", "agent", "experiments"],
  "files": [
    "dist",
    "src",
    "openclaw.plugin.json",
    "README.md"
  ]
}
